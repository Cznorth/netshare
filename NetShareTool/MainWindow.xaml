<Window x:Class="NetShareTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="网络共享工具" Height="660" Width="980" MinHeight="620" MinWidth="820"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F6F7F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1F2937" Padding="24,18">
            <StackPanel>
                <TextBlock Text="网络共享工具" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Text="选择能上网的网卡和要共享出去的网卡，然后开启 Windows ICS。"
                           Foreground="#D1D5DB" Margin="0,6,0,0" FontSize="14" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="18">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="共享设置" FontSize="18" FontWeight="SemiBold" Foreground="#111827" />
                        <TextBlock Text="来源网卡" Margin="0,18,0,6" Foreground="#4B5563" />
                        <ComboBox x:Name="PublicAdapterCombo" DisplayMemberPath="DisplayName" MinHeight="34" />
                        <TextBlock x:Name="PublicDescriptionText" TextWrapping="Wrap" Foreground="#6B7280" Margin="0,6,0,0" />

                        <TextBlock Text="共享出口" Margin="0,18,0,6" Foreground="#4B5563" />
                        <ComboBox x:Name="PrivateAdapterCombo" DisplayMemberPath="DisplayName" MinHeight="34" />
                        <TextBlock x:Name="PrivateDescriptionText" TextWrapping="Wrap" Foreground="#6B7280" Margin="0,6,0,0" />

                        <Button x:Name="EnableButton" Content="开启共享" Height="38" Margin="0,24,0,0"
                                Background="#2563EB" Foreground="White" BorderThickness="0" Click="EnableButton_Click" />
                        <Button x:Name="TransparentHotspotButton" Content="开启透明代理热点" Height="38" Margin="0,10,0,0"
                                Background="#059669" Foreground="White" BorderThickness="0" Click="TransparentHotspotButton_Click" />
                        <Button x:Name="DisableButton" Content="禁用全部共享" Height="38" Margin="0,10,0,0"
                                Background="#E5E7EB" Foreground="#111827" BorderThickness="0" Click="DisableButton_Click" />
                        <Button x:Name="RefreshButton" Content="刷新状态" Height="34" Margin="0,10,0,0"
                                Background="White" Foreground="#111827" BorderBrush="#D1D5DB" Click="RefreshButton_Click" />
                        <Button x:Name="OpenLogButton" Content="打开日志目录" Height="34" Margin="0,10,0,0"
                                Background="White" Foreground="#111827" BorderBrush="#D1D5DB" Click="OpenLogButton_Click" />

                        <TextBlock Text="提示：共享出口设备通常需要自动获取 IP，Windows ICS 默认网关是 192.168.137.1。"
                                   TextWrapping="Wrap" Foreground="#6B7280" Margin="0,22,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="18">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="当前 ICS 状态" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,14" />
                    <DataGrid x:Name="StatusGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" CanUserDeleteRows="False" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" BorderBrush="#E5E7EB" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="网卡名称" Binding="{Binding Name}" Width="*" />
                            <DataGridCheckBoxColumn Header="已共享" Binding="{Binding SharingEnabled}" Width="90" />
                            <DataGridTextColumn Header="类型" Binding="{Binding SharingConnectionType}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="18,10">
            <TextBlock x:Name="StatusText" Text="准备就绪" Foreground="#374151" TextTrimming="CharacterEllipsis" />
        </Border>
    </Grid>
</Window>
